---
const features = [
  {
    title: "Privacy First",
    description:
      "No tracking, no data collection. Optional YouTube login only when you want to sync your library.",
    icon: "🛡️",
  },
  {
    title: "Seamless Switching",
    description:
      "Toggle between audio and video modes instantly without interrupting your playback.",
    icon: "🔄",
  },
  {
    title: "Offline Freedom",
    description:
      "Download your favorite tracks and videos to enjoy them anytime, anywhere, without an internet connection.",
    icon: "⬇️",
  },
  {
    title: "Background Play",
    description:
      "Keep the music going even when the app is in the background or your screen is locked.",
    icon: "🎧",
  },
  {
    title: "PiP Mode",
    description:
      "Watch videos in a floating window while using other apps. Multitasking made easy.",
    icon: "📺",
  },
  {
    title: "Pixel Perfect UI",
    description:
      "A meticulously designed interface that feels as good as it looks. Modern, clean, and intuitive.",
    icon: "🎨",
  },
];
---

<section id="features" class="section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">
        Built for the <span class="gradient-text">Modern Listener.</span>
      </h2>
      <p class="section-subtitle">
        BlissBox combines high-end features with a commitment to user privacy
        and aesthetic excellence.
      </p>
    </div>

    <div class="features-grid">
      {
        features.map((feature) => (
          <div class="glass-card feature-card">
            <div class="feature-icon">
              {feature.icon.startsWith("/") ? (
                <img
                  src={feature.icon}
                  alt={feature.title}
                  class="feature-icon-img"
                />
              ) : (
                feature.icon
              )}
            </div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    font-family: "Outfit", sans-serif;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .feature-icon-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .feature-title {
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .feature-description {
    color: var(--text-secondary);
    font-size: 1rem;
  }
</style>
